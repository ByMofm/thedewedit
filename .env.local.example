NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp — número sin +, sin espacios, sin guiones. Ejemplo Arg: 5491155551234
NEXT_PUBLIC_WHATSAPP_NUMBER=5493815456600

# Mercado Pago — pedí sandbox en https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Google Sheets — IDs de cada spreadsheet (la parte entre /d/ y /edit en la URL).
# Con estos configurados, `pnpm sheets:sync` y el prebuild leen desde los Sheets y
# regeneran src/lib/data/products-raw.ts y src/lib/data/stock.ts automáticamente.
# Cada Sheet debe ser público: Compartir → "Cualquiera con el enlace" → Lector.
SHEETS_PRODUCTOS_ID=
SHEETS_VARIANTES_ID=
SHEETS_STOCK_ID=

# Alternativa: un solo Sheet con 3 pestañas ("Productos", "Variantes", "Stock").
# Solo si usás el formato de un Sheet con 3 pestañas en lugar de 3 Sheets separados.
# SHEETS_ID=

# Publicación desde Google Sheets — el Apps Script del Sheet llama a /api/publish
# con este secret para triggear un redeploy en Vercel.
# Generá uno con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PUBLISH_SECRET=

# Andreani — credenciales de la API para cotización de envíos.
# Sin estas vars el cotizador muestra "no disponible" y el checkout sigue funcionando.
# Obtenelas en https://desarrolladores.andreani.com/
ANDREANI_USUARIO=
ANDREANI_CLAVE=
ANDREANI_CONTRATO=

# Variables necesarias en Vercel para que /api/publish funcione (no las pongas acá):
#   VERCEL_DEPLOY_TOKEN  — token de la CLI de Vercel
#   VERCEL_PROJECT_ID    — ID del proyecto (prj_...)
