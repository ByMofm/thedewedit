NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp — número sin +, sin espacios, sin guiones. Ejemplo Arg: 5491155551234
NEXT_PUBLIC_WHATSAPP_NUMBER=5493815456600

# Mercado Pago — pedí sandbox en https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Secret para validar la firma del webhook (panel MP → Webhooks → "Clave secreta").
# Sin esto, el webhook acepta notificaciones sin verificar (modo dev).
MP_WEBHOOK_SECRET=

# ── Google Sheet "caja negra" (catálogo + stock + órdenes) ───────────────────
# 1 sola planilla con pestañas "Productos", "Variantes", "Órdenes".
# ID = la parte entre /d/ y /edit en la URL. Dejá la planilla con lectura pública
# (Compartir → "Cualquiera con el enlace" → Lector) para que el build la lea.
# Sin SHEETS_ID, `pnpm sheets:sync` usa los CSV locales de data/sheets-export-*.csv.
SHEETS_ID=

# Service account de Google (escritura: admin + descuento de stock al vender).
# Crear en Google Cloud → IAM → Service Accounts, descargar el JSON, habilitar la
# Google Sheets API, y COMPARTIR la planilla con este email como Editor.
# La private key va con \n literales o saltos de línea reales (ambos funcionan).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Panel admin (/admin) ──────────────────────────────────────────────────────
# Contraseña única para entrar a /admin. Elegí una larga.
ADMIN_PASSWORD=

# Subida de imágenes — Vercel Blob. Se setea solo al vincular un Blob store en
# Vercel (Storage → Blob). Para subir imágenes en local, pegá acá ese token.
BLOB_READ_WRITE_TOKEN=

# ── Publicación / redeploy ────────────────────────────────────────────────────
# Secret para /api/publish (disparador externo de redeploy, opcional).
# Generá uno con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PUBLISH_SECRET=
# Necesarias para el redeploy (las usa el botón "Publicar" del admin y el webhook):
VERCEL_DEPLOY_TOKEN=
VERCEL_PROJECT_ID=

# ── Envío gratis ──────────────────────────────────────────────────────────────
# Monto desde el cual el envío es gratis. 0 o vacío = desactivado (siempre se
# cobra envío y no se muestra la promesa de "envío gratis" en el sitio).
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=0

# ── Andreani — cotización de envíos ───────────────────────────────────────────
# Sin estas vars el cotizador usa el fallback de tarifa plana por zona.
# Credencial ID: generala en https://pymes.andreani.com/integraciones/ (opción WooCommerce).
ANDREANI_CREDENCIAL_ID=
ANDREANI_CP_ORIGEN=
